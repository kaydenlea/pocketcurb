#!/bin/sh
set -eu

if [ "${GAMA_BYPASS_LOCAL_GATES:-0}" = "1" ]; then
  echo "Gama local gates bypassed via GAMA_BYPASS_LOCAL_GATES=1"
  exit 0
fi

if git diff --cached --quiet; then
  echo "No staged changes. Skipping pre-commit gate."
  exit 0
fi

export GAMA_STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

node ./scripts/pre-commit.mjs
