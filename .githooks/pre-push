#!/bin/sh
set -eu

if [ "${POCKETCURB_BYPASS_LOCAL_GATES:-0}" = "1" ]; then
  echo "PocketCurb local gates bypassed via POCKETCURB_BYPASS_LOCAL_GATES=1"
  exit 0
fi

branch="$(git rev-parse --abbrev-ref HEAD)"
case "$branch" in
  main|master|release/*)
    if [ "${POCKETCURB_ALLOW_PROTECTED_PUSH:-0}" != "1" ]; then
      echo "Direct pushes to protected branch '$branch' are blocked. Push a feature branch and open a PR." >&2
      exit 1
    fi
    ;;
esac

node ./scripts/verify.mjs

base_ref="${POCKETCURB_REVIEW_BASE:-}"
if [ -z "$base_ref" ]; then
  for candidate in main origin/main master origin/master; do
    if git rev-parse --verify --quiet "$candidate" >/dev/null 2>&1; then
      base_ref="$candidate"
      break
    fi
  done
fi

if [ -z "$base_ref" ]; then
  if git rev-parse --verify --quiet HEAD~1 >/dev/null 2>&1; then
    base_ref="HEAD~1"
  else
    base_ref="HEAD"
  fi
fi

artifact_dir="$(git rev-parse --git-dir)/pocketcurb"
mkdir -p "$artifact_dir"
changed_files_path="$artifact_dir/changed-files.txt"

if [ "$base_ref" = "HEAD" ]; then
  git show --pretty= --name-only HEAD >"$changed_files_path"
else
  git diff --name-only "$base_ref...HEAD" >"$changed_files_path"
fi

codex_review_status="skipped"
codex_review_message="Codex review not attempted"

if [ "${POCKETCURB_DISABLE_AI_REVIEW:-0}" != "1" ]; then
  if ! command -v codex >/dev/null 2>&1; then
    echo "Codex CLI is not installed or not on PATH. Install Codex CLI or set POCKETCURB_DISABLE_AI_REVIEW=1 only when an explicit bypass is justified." >&2
    exit 1
  fi

  codex_review_output="$artifact_dir/codex-review.txt"
  if [ "$base_ref" = "HEAD" ]; then
    if codex review --commit HEAD >"$codex_review_output" 2>&1; then
      codex_review_status="passed"
      codex_review_message="Codex review completed successfully"
    else
      codex_review_status="failed"
      codex_review_message="Codex review failed. See $codex_review_output"
    fi
  else
    if codex review --base "$base_ref" >"$codex_review_output" 2>&1; then
      codex_review_status="passed"
      codex_review_message="Codex review completed successfully"
    else
      codex_review_status="failed"
      codex_review_message="Codex review failed. See $codex_review_output"
    fi
  fi

  if [ "$codex_review_status" != "passed" ]; then
    echo "$codex_review_message" >&2
    exit 1
  fi
else
  codex_review_message="Codex review disabled via POCKETCURB_DISABLE_AI_REVIEW=1"
fi

export POCKETCURB_BRANCH="$branch"
export POCKETCURB_BASE_REF="$base_ref"
export POCKETCURB_CHANGED_FILES_FILE="$changed_files_path"
export POCKETCURB_CODEX_REVIEW_STATUS="$codex_review_status"
export POCKETCURB_CODEX_REVIEW_MESSAGE="$codex_review_message"

node ./scripts/local-review.mjs
