{
  "name": "@pocketcurb/mobile",
  "private": true,
  "version": "0.1.0",
  "description": "Primary PocketCurb mobile product lane built with Expo, Expo Router, React Native, and TypeScript.",
  "scripts": {
    "dev": "expo start --clear",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config jest.config.cjs --runInBand --testPathPatterns=apps/mobile",
    "verify": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "main": "expo-router/entry",
  "dependencies": {
    "@gluestack-ui/themed": "^1.1.67",
    "@gluestack-style/react": "^1.0.57",
    "@hookform/resolvers": "^3.10.0",
    "@pocketcurb/api-client": "workspace:*",
    "@pocketcurb/core-domain": "workspace:*",
    "@pocketcurb/schemas": "workspace:*",
    "@pocketcurb/supabase-types": "workspace:*",
    "@pocketcurb/ui-mobile": "workspace:*",
    "@shopify/flash-list": "^1.7.3",
    "@supabase/supabase-js": "^2.49.2",
    "@tanstack/react-query": "^5.69.0",
    "expo": "^52.0.28",
    "expo-application": "^6.0.2",
    "expo-device": "^7.0.2",
    "expo-linking": "^7.0.5",
    "expo-router": "^4.0.17",
    "expo-secure-store": "^14.0.1",
    "expo-status-bar": "^2.0.1",
    "nativewind": "^4.1.23",
    "posthog-react-native": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-native": "^0.76.7",
    "react-native-gesture-handler": "^2.24.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-purchases": "^8.8.0",
    "react-native-reanimated": "^3.16.7",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^4.5.0",
    "react-native-svg": "^15.10.1",
    "react-native-web": "^0.19.13",
    "sentry-expo": "^7.0.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "babel-preset-expo": "^12.0.0",
    "jest-expo": "^52.0.5",
    "tailwindcss": "^3.4.17"
  }
