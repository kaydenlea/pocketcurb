{
  "name": "@pocketcurb/mobile",
  "private": true,
  "version": "0.1.0",
  "description": "Primary PocketCurb mobile product lane built with Expo, Expo Router, React Native, and TypeScript.",
  "scripts": {
    "dev": "expo start --clear",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config jest.config.cjs --runInBand --testPathPatterns=apps/mobile",
    "verify": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "main": "expo-router/entry",
  "dependencies": {
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/themed": "^1.1.67",
    "@hookform/resolvers": "^3.10.0",
    "@pocketcurb/api-client": "workspace:*",
    "@pocketcurb/core-domain": "workspace:*",
    "@pocketcurb/schemas": "workspace:*",
    "@pocketcurb/supabase-types": "workspace:*",
    "@pocketcurb/ui-mobile": "workspace:*",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.49.2",
    "@tanstack/react-query": "^5.69.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.1.23",
    "posthog-react-native": "^3.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.81.5",
    "react-native-css-interop": "0.2.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-purchases": "^8.8.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "sentry-expo": "~7.0.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
