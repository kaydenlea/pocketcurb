{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@gama/core-domain": [
        "../../packages/core-domain/src/index.ts"
      ],
      "@gama/schemas": [
        "../../packages/schemas/src/index.ts"
      ],
      "@gama/api-client": [
        "../../packages/api-client/src/index.ts"
      ],
      "@gama/supabase-types": [
        "../../packages/supabase-types/src/index.ts"
      ],
      "@gama/ui-mobile": [
        "../../packages/ui-mobile/src/index.tsx"
      ]
    }
  },
  "include": [
    ".expo/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "expo-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "*.ts",
    "*.tsx",
    "*.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
