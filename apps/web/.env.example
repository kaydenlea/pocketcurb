# Public web configuration for the marketing and SEO lane.
# The website is branded Gama, but it can use the PocketCurb Supabase project.

NEXT_PUBLIC_SITE_URL=http://localhost:3000
GAMA_DISABLE_INDEXING=true

# Waitlist backend. Keep unset until the intake form and launch disclosures are ready.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
WAITLIST_FROM_EMAIL="Gama <waitlist@example.test>"
WAITLIST_NOTIFY_EMAIL=team@example.test
