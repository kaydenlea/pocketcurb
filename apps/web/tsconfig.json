{
  "extends": "../../packages/config-typescript/web.json",
  "compilerOptions": {
    "types": [
      "react",
      "node",
      "jest"
    ],
    "paths": {
      "@pocketcurb/core-domain": [
        "../../packages/core-domain/src/index.ts"
      ],
      "@pocketcurb/schemas": [
        "../../packages/schemas/src/index.ts"
      ],
      "@pocketcurb/ui-web": [
        "../../packages/ui-web/src/index.tsx"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true,
    "jsx": "preserve"
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
