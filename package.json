{
  "name": "pocketcurb",
  "private": true,
  "version": "0.1.0",
  "description": "Security-first, agent-optimized pnpm monorepo for the PocketCurb decision-first personal finance operating system.",
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0 <23",
    "pnpm": ">=10.6.2 <11"
  },
  "scripts": {
    "bootstrap:local": "node ./scripts/bootstrap-local.mjs",
    "mobile:start": "node ./scripts/mobile-start.mjs",
    "mobile:dev": "node ./scripts/mobile-start.mjs --clear",
    "hooks:install": "node ./scripts/install-hooks.mjs",
    "new:product-brief": "node ./scripts/new-doc.mjs product-brief",
    "new:prd": "node ./scripts/new-doc.mjs prd",
    "new:spec:mobile": "node ./scripts/new-spec.mjs mobile",
    "new:spec:web": "node ./scripts/new-spec.mjs web",
    "new:feature-spec": "node ./scripts/new-doc.mjs feature-spec",
    "new:implementation-plan": "node ./scripts/new-doc.mjs implementation-plan",
    "new:bugfix-spec": "node ./scripts/new-doc.mjs bugfix-spec",
    "lint": "node ./scripts/lint.mjs",
    "policy:check": "node ./scripts/policy-check.mjs",
    "supabase:check-security": "node ./scripts/check-supabase-security.mjs",
    "typecheck": "node ./scripts/typecheck.mjs",
    "test": "node ./scripts/test.mjs",
    "test:unit": "node ./scripts/test-unit.mjs",
    "test:integration": "node ./scripts/test-integration.mjs",
    "test:e2e": "node ./scripts/test-e2e.mjs",
    "verify:mobile": "node ./scripts/verify-mobile.mjs",
    "verify:web": "node ./scripts/verify-web.mjs",
    "commit:check": "node ./scripts/pre-commit.mjs",
    "push:check": "node ./scripts/pre-push.mjs",
    "review:local": "node ./scripts/local-review.mjs",
    "review:ai": "node ./scripts/review-ai.mjs",
    "ai:check": "node ./scripts/check-ai-review-readiness.mjs",
    "pr:body": "node ./scripts/pr-body.mjs",
    "pr:create": "node ./scripts/pr-create.mjs",
    "env:check-tooling": "node ./scripts/networked-tooling-env.mjs install",
    "review:ready": "node ./scripts/review-ready.mjs",
    "pr:metadata:check": "node ./scripts/check-pr-metadata.mjs",
    "verify": "node ./scripts/verify.mjs",
    "audit": "node ./scripts/pnpm.mjs audit --audit-level=critical",
    "approve-builds": "node ./scripts/pnpm.mjs approve-builds",
    "docs:check": "node ./scripts/check-docs.mjs",
    "docs:reconcile": "node ./scripts/reconcile-docs.mjs"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
    "@eslint/js": "^9.24.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.3.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0"
  }
}
