{
  "extends": "./packages/config-typescript/web.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["jest", "node", "react"],
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@gama/core-domain": ["./packages/core-domain/src/index.ts"],
      "@gama/schemas": ["./packages/schemas/src/index.ts"],
      "@gama/api-client": ["./packages/api-client/src/index.ts"],
      "@gama/supabase-types": ["./packages/supabase-types/src/index.ts"],
      "@gama/ui-web": ["./packages/ui-web/src/index.tsx"]
    }
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx", "apps/web/**/*.ts", "apps/web/**/*.tsx"]
}
